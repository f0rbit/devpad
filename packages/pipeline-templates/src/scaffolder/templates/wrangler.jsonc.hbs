{
	"$schema": "../../../../../node_modules/wrangler/config-schema.json",
	"name": "{{package_name}}",
	"main": "src/index.ts",
	"compatibility_date": "{{compatibility_date}}",
	// rpc is default since 2024-04-03 and rejected by CF when set explicitly
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"env": {
		"staging": {
			"name": "{{package_name}}-staging"
		},
		"production": {
			"name": "{{package_name}}"
		}
	},
	"services": [
		{
			"binding": "ANTHROPIC",
			"service": "vault-staging",
			"entrypoint": "AnthropicVault"
		},
		{
			"binding": "PULSE",
			"service": "pulse-api-staging"
		}
	]
}
