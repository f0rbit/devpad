{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "devpad-pipelines",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-01",
	// `rpc` is default since 2024-04-03 and is rejected by Cloudflare when
	// specified explicitly — only `nodejs_compat` is needed.
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	// The Worker exports two RPC-callable classes:
	// - default Hono `fetch` (orchestrator routes)
	// - `PipelinesGrantsEndpoint extends WorkerEntrypoint` (consumed by vault via
	//   `services[].entrypoint = "PipelinesGrantsEndpoint"`)
	// Both classes share the same `DB` binding below.
	"durable_objects": {
		"bindings": [
			{
				"name": "PIPELINE_RUNS",
				"class_name": "PipelineRunDO"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["PipelineRunDO"]
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "devpad-unified-db",
			"database_id": "43bc9f1b-70a9-4844-b3c6-9c95e14bacbf"
		}
	],
	"r2_buckets": [
		{
			"binding": "CORPUS_BUCKET",
			"bucket_name": "devpad-corpus"
		}
	],
	"services": [
		{
			"binding": "ANTHROPIC",
			"service": "vault-production",
			"entrypoint": "AnthropicVault"
		},
		{
			"binding": "PULSE",
			"service": "pulse-api-production"
		}
	],
	"vars": {
		"ENVIRONMENT": "production"
	},
	"env": {
		"staging": {
			"name": "devpad-pipelines-staging",
			"vars": {
				"ENVIRONMENT": "staging"
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "devpad-unified-db-preview",
					"database_id": "e162775e-2c68-40ac-8ef4-446fd30ba24c"
				}
			],
			"r2_buckets": [
				{
					"binding": "CORPUS_BUCKET",
					"bucket_name": "devpad-corpus-staging"
				}
			],
			"services": [
				{
					"binding": "ANTHROPIC",
					"service": "vault-staging",
					"entrypoint": "AnthropicVault"
				},
				{
					"binding": "PULSE",
					"service": "pulse-api-staging"
				}
			]
		},
		"production": {
			"name": "devpad-pipelines",
			"vars": {
				"ENVIRONMENT": "production"
			}
		}
	}
}
