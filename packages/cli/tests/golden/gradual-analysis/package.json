{
	"name": "gradual-analysis",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"description": "Pipeline-managed Cloudflare Worker generated by `devpad pipelines init`",
	"main": "src/index.ts",
	"scripts": {
		"dev": "wrangler dev",
		"build": "bun build src/index.ts --outdir dist --target browser --packages=external",
		"deploy:plan": "bunx alchemy run infra.ts --dry-run",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"e2e": "playwright test"
	},
	"dependencies": {
		"@f0rbit/corpus": "^0.4.0",
		"zod": "^3.22.4"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20240520.0",
		"@playwright/test": "^1.55.0",
		"alchemy": "^0.50.0",
		"playwright": "^1.55.0",
		"typescript": "^5.3.3",
		"wrangler": "^3.86.0"
	}
}
