{
	"$schema": "../../../../../node_modules/wrangler/config-schema.json",
	"name": "gradual-analysis",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-17",
	// rpc is default since 2024-04-03 and rejected by CF when set explicitly
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"env": {
		"staging": {
			"name": "gradual-analysis-staging"
		},
		"production": {
			"name": "gradual-analysis"
		}
	},
	"services": [
		{
			"binding": "ANTHROPIC",
			"service": "vault-staging",
			"entrypoint": "AnthropicVault"
		},
		{
			"binding": "PULSE",
			"service": "pulse-api-staging"
		}
	]
}
