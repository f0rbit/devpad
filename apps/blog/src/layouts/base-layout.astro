---
import "@devpad/core/ui/styles";

interface Props {
	title: string;
	description?: string;
	canonical?: string;
	noindex?: boolean;
}

const DEFAULT_DESCRIPTION = "A blog platform for developers. Write in markdown, link posts to projects, and publish with version control.";

const { title, description = DEFAULT_DESCRIPTION, canonical, noindex = false } = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://use.typekit.net/jmv8pmn.css" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{title} | devpad blog</title>

    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | devpad blog`} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="devpad blog" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={`${title} | devpad blog`} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
