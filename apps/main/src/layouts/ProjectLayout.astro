---
import { getServerApiClient } from "@devpad/core/ui/api-client";

interface Props {
	project_id: string;
}

const { project_id } = Astro.props;

// Best-effort lookup of pending pipeline approvals for the badge on the Pipeline tab.
// Failures degrade gracefully: no badge, tab still renders (empty-state landing handles the rest).
let pending_approval_count = 0;
if (Astro.locals.user) {
	const client = getServerApiClient(Astro.locals);
	const project_result = await client.projects.getByName(project_id);
	if (project_result.ok && project_result.value) {
		const pkg_result = await client.pipelines.packages.list({ project_id: project_result.value.id });
		if (pkg_result.ok && pkg_result.value.length > 0) {
			const pkg_id = pkg_result.value[0]!.id;
			const runs_result = await client.pipelines.list({ package_id: pkg_id, status: "awaiting_approval" });
			if (runs_result.ok) pending_approval_count = runs_result.value.length;
		}
	}
}

const pipeline_label = pending_approval_count > 0 ? `pipeline (${pending_approval_count} awaiting)` : "pipeline";

// Tab order — pipeline slots after pulse, before blog (operational sibling of pulse).
const pages = [
	{ name: "overview", label: "overview", href: `/project/${project_id}` },
	{ name: "goals", label: "goals", href: `/project/${project_id}/goals` },
	{ name: "tasks", label: "tasks", href: `/project/${project_id}/tasks` },
	{ name: "pulse", label: "pulse", href: `/project/${project_id}/pulse` },
	{ name: "pipeline", label: pipeline_label, href: `/project/${project_id}/pipeline` },
	{ name: "blog", label: "blog", href: `/project/${project_id}/blog` },
	{ name: "settings", label: "settings", href: `/project/${project_id}/settings` },
	{ name: "specification", label: "specification", href: `/project/${project_id}/specification` },
	{ name: "history", label: "history", href: `/project/${project_id}/history` },
];

const search_pages = pages.filter(p => p.name !== "overview");
const active = search_pages.find(p => Astro.url.pathname.startsWith(p.href))?.name ?? "overview";
---

<main>
	<h1>{project_id}</h1>
	<nav>
		{
			pages.map((p) => (
				<a href={p.href} class={active == p.name ? "active" : ""}>
					{p.label}
				</a>
			))
		}
	</nav>
	<br />
	<slot />
</main>
