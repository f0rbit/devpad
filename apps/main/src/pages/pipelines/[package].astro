---
import { getServerApiClient } from "@devpad/core/ui/api-client";
import type { PipelineRun } from "@devpad/schema";
import PageLayout from "@/layouts/PageLayout.astro";
import { rethrow } from "@/utils/api-client";

// @ts-ignore rethrow is used in conditional return path
void rethrow;

const { package: package_id } = Astro.params;
const user = Astro.locals.user;
let runs: PipelineRun[] = [];

if (user && package_id) {
	const client = getServerApiClient(Astro.locals);
	const result = await client.pipelines.list();
	if (!result.ok) return rethrow(result.error);
	// Filter runs for this package
	runs = result.value.filter(r => r.package_id === package_id).slice(0, 10);
}

const keywords = ["pipelines", "package", "releases", "version-set"];
---

<PageLayout
	title={`Package ${package_id} - devpad`}
	description="Package deployment details. View version sets and recent runs."
	keywords={keywords}
	canonical={`https://devpad.tools/pipelines/${package_id}`}
>
	{
		user ? (
			<main>
				<div class="row row-sm" style="margin-bottom: 1rem;">
					<div>
						<a href="/pipelines" style="text-decoration: none; color: var(--text-link); font-size: 0.9rem;">
							← back to pipelines
						</a>
						<h1 style="margin: 0.5rem 0 0 0;">{package_id}</h1>
					</div>
				</div>

				<div class="stack stack-lg">
					<div class="stack stack-md">
						<h2>recent runs</h2>
						{runs.length === 0 ? (
							<p class="text-muted">No runs yet for this package.</p>
						) : (
							<div class="stack stack-sm">
								{runs.map(run => (
									<a href={`/pipelines/runs/${run.id}`} style="text-decoration: none; color: inherit;">
										<div class="card card-interactive stack stack-xs">
											<div class="row row-between">
												<div style="flex: 1;">
													<h3 style="margin: 0; font-size: 0.95rem;">{run.id.substring(0, 8)}</h3>
													<p class="text-xs text-faint" style="margin: 0.25rem 0 0 0;">
														{run.status} · {run.current_stage || "queued"}
													</p>
												</div>
												<span
													class="status-badge"
													style={`
														padding: 0.25rem 0.75rem;
														border-radius: 0.25rem;
														font-size: 0.8rem;
														background: ${
															run.status === "completed"
																? "var(--success-bg)"
																: run.status === "rolled_back"
																	? "var(--success-bg)"
																	: run.status === "failed" || run.status === "cancelled"
																		? "var(--error-bg)"
																		: (run.status === "deploying" || run.status === "baking" || run.status === "rolling_back")
																			? "var(--info-bg)"
																			: "var(--bg-alt)"
														};
														color: ${
															run.status === "completed"
																? "var(--success)"
																: run.status === "rolled_back"
																	? "var(--success)"
																	: run.status === "failed" || run.status === "cancelled"
																		? "var(--error)"
																		: (run.status === "deploying" || run.status === "baking" || run.status === "rolling_back")
																			? "var(--info)"
																			: "var(--fg-muted)"
														};
													`}
												>
													{run.status}
												</span>
											</div>
										</div>
									</a>
								))}
							</div>
						)}
					</div>
				</div>
			</main>
		) : (
			<main>
				<section class="landing-hero">
					<h1>access denied</h1>
					<p class="text-muted">You must be signed in to view pipeline details.</p>
				</section>
			</main>
		)
	}
</PageLayout>
